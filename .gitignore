# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# TLS / secrets locaux
*.key
*.pem
*.crt

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# factures générées
/invoices
# contrats générés
/contracts
# devis générés
/quotes

